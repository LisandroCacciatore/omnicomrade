<!DOCTYPE html>
<html lang="es" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bienvenido a TechFitness — Configuración</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=IBM+Plex+Mono:wght@400;600&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <!-- Icons -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#3B82F6',
                        success: '#10B981',
                        warning: '#F59E0B',
                        danger: '#EF4444',
                        surface: {
                            dark: '#161E26',
                            base: '#0B1218'
                        },
                        border: {
                            dark: 'rgba(30,41,59,0.5)'
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Space+Grotesk', 'sans-serif'],
                        mono: ['IBM Plex Mono', 'monospace']
                    }
                }
            }
        }
    </script>
    <style>
        .glass-panel {
            background: rgba(22, 30, 38, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .step-inactive { opacity: 0.3; }
        .step-active { opacity: 1; border-color: #3B82F6; }
        .step-done { opacity: 1; color: #10B981; }
        
        /* Animación para celebración */
        @keyframes bounce-in {
            0% { transform: scale(0); }
            60% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
        .animate-celebrate { animation: bounce-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }

        #toast {
            visibility: hidden; min-width: 250px; background-color: #333; color: #fff;
            text-align: center; border-radius: 12px; padding: 16px; position: fixed;
            z-index: 100; left: 50%; bottom: 40px; transform: translateX(-50%); font-size: 14px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1);
        }
        #toast.show { visibility: visible; animation: fadein 0.5s, fadeout 0.5s 2.5s; }
        @keyframes fadein { from { bottom: 0; opacity: 0; } to { bottom: 40px; opacity: 1; } }
        @keyframes fadeout { from { bottom: 40px; opacity: 1; } to { bottom: 0; opacity: 0; } }
    </style>
</head>
<body class="bg-surface-base text-slate-200 min-h-screen flex flex-col items-center justify-center p-4">

    <!-- Progress Bar -->
    <div id="onboarding-nav" class="w-full max-w-4xl mb-12 flex items-center justify-between px-2">
        <div class="flex-1 flex flex-col items-center gap-2 group" data-step="1">
            <div class="step-circle w-10 h-10 rounded-full border-2 flex items-center justify-center font-bold font-mono transition-all step-active">1</div>
            <span class="text-[10px] uppercase tracking-widest font-bold opacity-60">Gimnasio</span>
        </div>
        <div class="h-[2px] flex-1 bg-slate-800 mx-4"></div>
        <div class="flex-1 flex flex-col items-center gap-2" data-step="2">
            <div class="step-circle w-10 h-10 rounded-full border-2 border-slate-800 flex items-center justify-center font-bold font-mono opacity-30">2</div>
            <span class="text-[10px] uppercase tracking-widest font-bold opacity-30">Atleta</span>
        </div>
        <div class="h-[2px] flex-1 bg-slate-800 mx-4"></div>
        <div class="flex-1 flex flex-col items-center gap-2" data-step="3">
            <div class="step-circle w-10 h-10 rounded-full border-2 border-slate-800 flex items-center justify-center font-bold font-mono opacity-30">3</div>
            <span class="text-[10px] uppercase tracking-widest font-bold opacity-30">Membresía</span>
        </div>
        <div class="h-[2px] flex-1 bg-slate-800 mx-4"></div>
        <div class="flex-1 flex flex-col items-center gap-2" data-step="4">
            <div class="step-circle w-10 h-10 rounded-full border-2 border-slate-800 flex items-center justify-center font-bold font-mono opacity-30">4</div>
            <span class="text-[10px] uppercase tracking-widest font-bold opacity-30">Programa</span>
        </div>
    </div>

    <!-- Main Container -->
    <main class="w-full max-w-5xl">
        
        <!-- STEP 1: Gimnasio -->
        <section id="step-1" class="wizard-step flex flex-col lg:flex-row gap-8 items-center lg:items-start">
            <div class="flex-1 space-y-6">
                <div>
                    <h1 class="font-display text-4xl font-bold bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">Configurá tu centro</h1>
                    <p class="text-slate-500 mt-2">Danos los detalles básicos de tu gimnasio para personalizar la plataforma.</p>
                </div>
                
                <div class="space-y-4">
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Nombre del Gimnasio</label>
                        <input type="text" id="gym-name" placeholder="Ej: Iron Works" class="w-full bg-surface-dark border border-border-dark rounded-xl px-4 py-3 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                    </div>

                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Color de Acento</label>
                        <div class="flex gap-3 pt-2" id="color-presets">
                            <button data-color="#3B82F6" class="w-10 h-10 rounded-full bg-blue-500 ring-offset-2 ring-offset-surface-base ring-2 ring-primary"></button>
                            <button data-color="#10B981" class="w-10 h-10 rounded-full bg-emerald-500 transition-transform hover:scale-110"></button>
                            <button data-color="#F59E0B" class="w-10 h-10 rounded-full bg-amber-500 transition-transform hover:scale-110"></button>
                            <button data-color="#8B5CF6" class="w-10 h-10 rounded-full bg-violet-500 transition-transform hover:scale-110"></button>
                            <button data-color="#EF4444" class="w-10 h-10 rounded-full bg-red-500 transition-transform hover:scale-110"></button>
                        </div>
                    </div>

                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Logo (Opcional)</label>
                        <div class="mt-1 flex items-center gap-4">
                            <label for="gym-logo" class="cursor-pointer bg-surface-dark border-2 border-dashed border-border-dark hover:border-primary/50 transition-colors rounded-xl px-4 py-3 flex items-center gap-2 text-sm text-slate-500">
                                <span class="material-symbols-rounded">upload_file</span>
                                <span id="logo-filename">Subir archivo</span>
                                <input type="file" id="gym-logo" class="hidden" accept="image/*">
                            </label>
                        </div>
                    </div>
                </div>

                <div class="flex items-center gap-4 pt-4">
                    <button id="btn-next-1" disabled class="disabled:opacity-50 disabled:cursor-not-allowed bg-primary text-white font-bold py-3 px-8 rounded-xl hover:bg-blue-600 transition-all flex items-center gap-2">
                        Siguiente
                        <span class="material-symbols-rounded">arrow_forward</span>
                    </button>
                    <button class="text-slate-500 text-sm font-bold hover:text-white transition-colors btn-skip">Saltar por ahora</button>
                </div>
            </div>

            <!-- Preview Card -->
            <div class="w-full lg:w-80 glass-panel rounded-3xl p-6 border-slate-700/50 shadow-2xl">
                <div class="flex flex-col items-center text-center gap-4">
                    <div id="preview-logo-circle" class="w-20 h-20 rounded-2xl bg-slate-800 flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-rounded text-3xl text-slate-600">fitness_center</span>
                    </div>
                    <div>
                        <h3 id="preview-gym-name" class="font-display font-bold text-xl text-white">Tu Gimnasio</h3>
                        <p class="text-xs text-slate-500 mt-1">Suscripción Profesional</p>
                    </div>
                    <div class="w-full pt-4 space-y-3">
                        <div class="h-2 w-full bg-slate-800/50 rounded-full overflow-hidden">
                            <div id="preview-accent-bar" class="h-full bg-primary w-2/3"></div>
                        </div>
                        <div class="flex justify-between text-[10px] font-mono text-slate-600 uppercase tracking-widest">
                            <span>Métricas Live</span>
                            <span id="preview-color-code">#3B82F6</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- STEP 2: Atleta -->
        <section id="step-2" class="wizard-step hidden flex flex-col max-w-2xl mx-auto space-y-8">
            <div class="text-center">
                <h2 class="font-display text-4xl font-bold bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">Agregá tu primer atleta</h2>
                <p class="text-slate-500 mt-2">Vamos a registrar al primer alumno para que veas cómo funciona el seguimiento.</p>
            </div>

            <div class="glass-panel rounded-3xl p-8 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Nombre Completo</label>
                        <input type="text" id="student-name" placeholder="Ej: Juan Pérez" class="w-full bg-surface-base border border-border-dark rounded-xl px-4 py-3 focus:border-primary outline-none transition-all">
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Email</label>
                        <input type="email" id="student-email" placeholder="juan@ejemplo.com" class="w-full bg-surface-base border border-border-dark rounded-xl px-4 py-3 focus:border-primary outline-none transition-all">
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Teléfono (Opcional)</label>
                        <input type="tel" id="student-phone" placeholder="+54..." class="w-full bg-surface-base border border-border-dark rounded-xl px-4 py-3 focus:border-primary outline-none transition-all">
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Objetivo</label>
                        <select id="student-goal" class="w-full bg-surface-base border border-border-dark rounded-xl px-4 py-3 focus:border-primary outline-none transition-all appearance-none">
                            <option value="fuerza">Fuerza</option>
                            <option value="hipertrofia">Hipertrofia</option>
                            <option value="perdida_peso">Pérdida de peso</option>
                            <option value="rendimiento">Rendimiento</option>
                            <option value="salud_general">Salud General</option>
                        </select>
                    </div>
                </div>

                <div class="flex flex-col items-center gap-4 pt-4">
                    <button id="btn-next-2" disabled class="w-full disabled:opacity-50 disabled:cursor-not-allowed bg-primary text-white font-bold py-4 rounded-xl hover:bg-blue-600 transition-all flex items-center justify-center gap-2">
                        Registrar Atleta
                        <span class="material-symbols-rounded">arrow_forward</span>
                    </button>
                    <button class="text-slate-500 text-xs font-bold hover:text-white transition-colors" id="btn-skip-students">Tengo más de un atleta — los cargo después</button>
                </div>
            </div>
        </section>

        <!-- STEP 3: Membresía -->
        <section id="step-3" class="wizard-step hidden flex flex-col max-w-2xl mx-auto space-y-8">
            <div class="text-center">
                <h2 class="font-display text-4xl font-bold bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">Registrá su membresía</h2>
                <p class="text-slate-500 mt-2">Activá el acceso de <span id="membership-student-preview" class="text-white font-bold">atleta</span> al gimnasio.</p>
            </div>

            <div class="glass-panel rounded-3xl p-8 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Plan</label>
                        <select id="membership-plan" class="w-full bg-surface-base border border-border-dark rounded-xl px-4 py-3 focus:border-primary outline-none transition-all">
                            <option value="mensual">Mensual</option>
                            <option value="trimestral">Trimestral</option>
                            <option value="anual">Anual</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Monto (ARS)</label>
                        <input type="number" id="membership-amount" placeholder="0.00" class="w-full bg-surface-base border border-border-dark rounded-xl px-4 py-3 focus:border-primary font-mono outline-none transition-all">
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Método de Pago</label>
                        <select id="membership-method" class="w-full bg-surface-base border border-border-dark rounded-xl px-4 py-3 focus:border-primary outline-none transition-all">
                            <option value="efectivo">Efectivo</option>
                            <option value="transferencia">Transferencia</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-400 uppercase tracking-tighter">Fecha de Inicio</label>
                        <input type="date" id="membership-date" class="w-full bg-surface-base border border-border-dark rounded-xl px-4 py-3 focus:border-primary outline-none transition-all">
                    </div>
                </div>

                <button id="btn-next-3" disabled class="w-full disabled:opacity-50 disabled:cursor-not-allowed bg-primary text-white font-bold py-4 rounded-xl hover:bg-blue-600 transition-all flex items-center justify-center gap-2">
                    Activar Membresía
                    <span class="material-symbols-rounded">verified</span>
                </button>
            </div>
        </section>

        <!-- STEP 4: Programa & RMs -->
        <section id="step-4" class="wizard-step hidden flex flex-col space-y-8">
            <div class="text-center">
                <h2 class="font-display text-4xl font-bold bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">Asigná un programa</h2>
                <p class="text-slate-500 mt-2">Elegí la metodología de entrenamiento para tu primer atleta.</p>
            </div>

            <!-- Program Selector -->
            <div id="program-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Skeletons while loading -->
                <div class="h-40 bg-slate-800 animate-pulse rounded-2xl"></div>
                <div class="h-40 bg-slate-800 animate-pulse rounded-2xl"></div>
                <div class="h-40 bg-slate-800 animate-pulse rounded-2xl"></div>
            </div>

            <!-- RMS Form (Hidden until program selected) -->
             <div id="rms-container" class="hidden glass-panel rounded-3xl p-8 transition-all">
                <div class="mb-6 flex items-center justify-between">
                    <div>
                        <h3 class="font-display text-xl font-bold">Ingresá sus marcas (1RM)</h3>
                        <p class="text-xs text-slate-500 uppercase tracking-tighter">Pesos en kg para cálculos de carga</p>
                    </div>
                    <div class="px-3 py-1 rounded bg-slate-800 text-[10px] font-bold text-primary border border-primary/20 uppercase" id="selected-program-tag">Starting Strength</div>
                </div>

                <div id="rms-inputs-grid" class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <!-- Dinámico -->
                </div>

                <button id="btn-finish" class="w-full mt-8 bg-success text-white font-bold py-4 rounded-xl hover:bg-emerald-600 transition-all flex items-center justify-center gap-2">
                    Finalizar Configuración
                    <span class="material-symbols-rounded">stars</span>
                </button>
             </div>
        </section>

        <!-- CELEBRATION -->
        <section id="celebration" class="wizard-step hidden flex flex-col items-center text-center space-y-8 py-12">
            <div class="w-32 h-32 rounded-full bg-success/10 flex items-center justify-center text-success animate-celebrate">
                <span class="material-symbols-rounded text-7xl">check_circle</span>
            </div>
            
            <div class="space-y-3">
                <h1 class="font-display text-5xl font-bold text-white">Tu gimnasio está listo.</h1>
                <p class="text-slate-400 max-w-md mx-auto">Acabás de crear tu primer atleta, registrar su membresía y asignarle un programa. Esto es lo que tu dashboard va a mostrar desde ahora.</p>
            </div>

            <div class="flex flex-wrap justify-center gap-4 w-full max-w-3xl">
                <!-- Mini Cards -->
                <div class="flex-1 min-w-[200px] glass-panel p-4 rounded-2xl text-left border-l-4 border-l-primary">
                    <span class="text-[10px] text-slate-500 uppercase font-bold tracking-widest block mb-1">Primer Atleta</span>
                    <p class="text-sm font-bold text-white uppercase" id="summary-name">Juan Pérez</p>
                    <p class="text-xs text-slate-500" id="summary-goal">Fuerza</p>
                </div>
                <div class="flex-1 min-w-[200px] glass-panel p-4 rounded-2xl text-left border-l-4 border-l-success">
                    <span class="text-[10px] text-slate-500 uppercase font-bold tracking-widest block mb-1">Membresía</span>
                    <p class="text-sm font-bold text-white uppercase" id="summary-plan">Mensual</p>
                    <p class="text-xs text-slate-500">Monto: $<span id="summary-amount">0</span></p>
                </div>
                <div class="flex-1 min-w-[200px] glass-panel p-4 rounded-2xl text-left border-l-4 border-l-violet-500">
                    <span class="text-[10px] text-slate-500 uppercase font-bold tracking-widest block mb-1">Programa</span>
                    <p class="text-sm font-bold text-white uppercase" id="summary-program">Starting Strength</p>
                    <p class="text-xs text-slate-500">4 Semanas generadas</p>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 pt-8 pb-12 w-full max-w-md">
                <button onclick="window.location.href='admin-dashboard.html'" class="flex-1 bg-white text-black font-bold py-4 rounded-xl hover:bg-slate-200 transition-all">Ir al dashboard</button>
                <button onclick="window.location.href='student-list.html'" class="flex-1 bg-surface-dark border border-border-dark text-white font-bold py-4 rounded-xl hover:bg-slate-800 transition-all">Agregar más atletas</button>
            </div>
        </section>

    </main>

    <!-- TOAST -->
    <div id="toast">
        <div class="flex items-center gap-3">
            <span id="toast-icon" class="material-symbols-rounded"></span>
            <span id="toast-msg"></span>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="js/auth-guard.js"></script>
    <script src="js/ui-utils.js"></script>
    <script src="js/training-math.js"></script>
    <script src="js/training-engine.js"></script>
    <script src="js/onboarding.js"></script>
</body>
</html>
