{
  "name": "omnicomrade",
  "version": "1.0.0",
  "description": "TechFitness - Sistema de gestión de gimnasio",
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-supabase-config.cjs",
    "dev": "vite",
    "dev:api": "node server/index.js",
    "build:vite": "vite build",
    "tailwind:build": "tailwindcss -i styles/tailwind.input.css -o dist/assets/tailwind.css --minify",
    "lint": "eslint",
    "lint:all": "eslint js/**/*.js tests/**/*.js",
    "format": "prettier --check .",
    "test:unit": "node --test tests/unit/*.test.js tests/unit/*/*.test.js",
    "test:contract": "node --test tests/contract/*.test.js",
    "test:e2e": "node --test tests/e2e/*.test.js",
    "test:all": "npm run test:unit && npm run test:contract && npm run test:e2e",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "postcss": "^8.5.8",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.0"
  }
}
