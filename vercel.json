{
    "cleanUrls": true,
    "trailingSlash": false,
    "outputDirectory": ".",
    "redirects": [
        {
            "source": "/",
            "destination": "/login",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/$1"
        }
    ]
}